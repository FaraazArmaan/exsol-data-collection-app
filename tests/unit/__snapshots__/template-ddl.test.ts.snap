  UNIQUE NULLS NOT DISTINCT (email)
);
CREATE INDEX "staff_created_at_idx" ON "client_a1b2c3d4e5f60123456789abcdef0123"."staff" (created_at DESC);

CREATE TABLE "client_a1b2c3d4e5f60123456789abcdef0123"."patients" (
