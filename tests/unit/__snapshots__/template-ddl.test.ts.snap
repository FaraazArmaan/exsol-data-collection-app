);
CREATE INDEX "nurses_created_at_idx" ON "client_a1b2c3d4e5f60123456789abcdef0123"."nurses" (created_at DESC);

CREATE TABLE "client_a1b2c3d4e5f60123456789abcdef0123"."staff" (
  id              uuid PRIMARY KEY DEFAULT gen_random_uuid(),
  display_name    text NOT NULL,
  email           citext,
  phone           text,
