{
  "name": "exsol-data-collection-app",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "netlify dev",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx --env-file=.env scripts/migrate.ts",
    "migrate:status": "tsx --env-file=.env scripts/migrate.ts --status",
    "bootstrap:admin": "tsx --env-file=.env scripts/bootstrap-admin.ts",
    "seed:inventory": "tsx --env-file=.env scripts/seed-inventory.ts",
    "seed:email": "tsx --env-file=.env scripts/seed-email.ts",
    "seed:finance": "tsx --env-file=.env scripts/seed-finance.ts",
    "seed:procurement": "tsx --env-file=.env scripts/seed-procurement.ts",
    "seed:warehouse": "tsx --env-file=.env scripts/seed-warehouse.ts",
    "seed:crm": "tsx --env-file=.env scripts/seed-crm.ts",
    "seed:workforce": "tsx --env-file=.env scripts/seed-workforce.ts",
    "seed:manufacturing": "tsx --env-file=.env scripts/seed-manufacturing.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/lora": "^5.2.8",
    "@fontsource-variable/merriweather": "^5.2.6",
    "@fontsource-variable/montserrat": "^5.2.8",
    "@fontsource-variable/open-sans": "^5.2.7",
    "@fontsource-variable/playfair-display": "^5.2.8",
    "@fontsource-variable/roboto": "^5.2.10",
    "@fontsource-variable/work-sans": "^5.2.8",
    "@fontsource/anton": "^5.2.7",
    "@fontsource/bebas-neue": "^5.2.7",
    "@fontsource/poppins": "^5.2.7",
    "@fontsource/pt-serif": "^5.2.8",
    "@fontsource/space-mono": "^5.2.9",
    "@neondatabase/serverless": "^0.10.0",
    "@netlify/blobs": "^10.7.9",
    "@node-rs/argon2": "^2.0.0",
    "google-auth-library": "^9.14.0",
    "jose": "^5.9.0",
    "jszip": "3.10.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^7.0.0",
    "recharts": "^3.9.1",
    "sharp": "0.33.5",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@netlify/functions": "^2.8.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.9",
    "jsdom": "^29.1.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
